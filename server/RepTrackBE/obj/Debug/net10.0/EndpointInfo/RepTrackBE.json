      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SaveCustomWorkoutRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "exerciseIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WorkoutBatchRequest": {
        "type": "object",
        "properties": {
          "workouts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkoutCreateRequest"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WorkoutCreateRequest": {
        "type": "object",
        "properties": {
          "exerciseId": {
            "type": "integer",
            "format": "int32"
          },
          "sets": {
            "type": "integer",
            "format": "int32"
          },
          "reps": {
            "type": "integer",
            "format": "int32"
          },
          "weight": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "RepTrackBE"
    }
  ]
